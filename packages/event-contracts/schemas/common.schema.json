{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.healuxa.com/events/common.schema.json",
  "title": "HealuxaCommonTypes",
  "description": "Reusable building blocks shared across all Healuxa event payloads. Referenced via $ref.",
  "$defs": {
    "Ulid": {
      "type": "string",
      "description": "ULID or UUID identifier.",
      "pattern": "^[0-9A-HJKMNP-TV-Za-hjkmnp-tv-z-]{16,36}$"
    },
    "TenantId": {
      "type": "string",
      "description": "Tenant scope; present on every event envelope and most payloads.",
      "minLength": 2,
      "maxLength": 64,
      "examples": ["healuxa-dubai"]
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 / ISO 8601 timestamp in UTC."
    },
    "CurrencyCode": {
      "type": "string",
      "description": "ISO 4217 currency code.",
      "pattern": "^[A-Z]{3}$",
      "default": "AED"
    },
    "Money": {
      "type": "object",
      "description": "Monetary amount. Integer minor units to avoid float error.",
      "additionalProperties": false,
      "required": ["amount_minor", "currency"],
      "properties": {
        "amount_minor": {
          "type": "integer",
          "description": "Amount in minor units (e.g. fils for AED)."
        },
        "currency": { "$ref": "#/$defs/CurrencyCode" }
      }
    },
    "Channel": {
      "type": "string",
      "enum": ["app", "web", "whatsapp", "email", "sms", "push", "in_app", "system"]
    },
    "Score01": {
      "type": "number",
      "description": "Normalized score in the [0,1] range.",
      "minimum": 0,
      "maximum": 1
    }
  }
}
