# Healuxa Identity Service — Healuxa_TechSpec.md §25.1 / §25.3
# Copy to .env and adjust per environment: laptop | Docker infra | Dokploy production

# ── Shared (all backend services, py-common ServiceSettings) ─────────────────
APP_ENV=development
SERVICE_NAME=identity-service
LOG_LEVEL=INFO
INTERNAL_NETWORK=healuxa-net
TENANT_DEFAULT=healuxa-dubai

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Used by downstream services for offline JWT validation (not required for identity itself)
JWT_PUBLIC_JWKS_URL=http://localhost:8001/.well-known/jwks.json

# ── PostgreSQL (identity logical DB — §8.4) ────────────────────────────────────
# Laptop + Docker infra on localhost:
DATABASE_URL=postgresql+asyncpg://healuxa:dev@localhost:5432/identity
# Docker Compose identity-service container (hostname `postgres`):
# DATABASE_URL=postgresql+asyncpg://healuxa:dev@postgres:5432/identity
# Dokploy / managed Postgres:
# DATABASE_URL=postgresql+asyncpg://healuxa:***@pgbouncer:6432/identity

# Tests only (do not use for development server):
# DATABASE_URL=postgresql+asyncpg://healuxa:dev@localhost:5432/identity_test

# ── Redis ────────────────────────────────────────────────────────────────────
# Laptop / tests:
REDIS_URL=redis://localhost:6379/0
# Docker Compose app container:
# REDIS_URL=redis://redis:6379/0
# Dokploy:
# REDIS_URL=redis://redis:6379/0

# ── NATS JetStream (event bus) ───────────────────────────────────────────────
# Laptop (infra via compose on localhost):
NATS_URL=nats://localhost:4222
# Docker Compose app container:
# NATS_URL=nats://nats:4222
NATS_ENABLED=false
# Set NATS_ENABLED=true when publishing to JetStream (compose `app` profile sets this)

# ── MongoDB Atlas (managed external — profile/assessment services; §25.6) ───
# Not used by identity-service today; documented for Dokploy env parity.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/healuxa
# MONGODB_CSFLE_KEY_VAULT=encryption.__keyVault
# AWS_KMS_KEY_ID=

# ── ClickHouse (analytics projections — provider-success / commercial / monitoring)
# Not used by identity-service today; infra available locally via compose.
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_URL=http://clickhouse:8123

# ── Identity IAM (§25.3) ─────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PEM=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=https://api.healuxa.com
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
PASSWORD_PEPPER=dev-pepper-change-me
MFA_ISSUER=Healuxa
MFA_ENCRYPTION_KEY=dev-mfa-key-32bytes-long!!!!!!
OTP_TTL=300
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_SECONDS=900

SERVICE_AUTH_CLIENT_ID=healuxa-internal
SERVICE_AUTH_CLIENT_SECRET=dev-service-secret-change-me
