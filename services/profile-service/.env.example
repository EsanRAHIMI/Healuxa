# Healuxa Profile Service — Healuxa_TechSpec.md §25.6
# Local dev uses MongoDB Atlas only (no local Mongo container).

APP_ENV=development
SERVICE_NAME=profile-service
LOG_LEVEL=INFO
INTERNAL_NETWORK=healuxa-net
TENANT_DEFAULT=healuxa-dubai

# MongoDB Atlas (required)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=healuxa_profile_dev

# Tests only — name MUST contain "test" (e.g. healuxa_profile_test)
# MONGODB_DATABASE=healuxa_profile_test

# CSFLE placeholders (not enabled in scaffold)
MONGODB_CSFLE_KEY_VAULT=encryption.__keyVault
AWS_KMS_KEY_ID=

JWT_PUBLIC_JWKS_URL=http://localhost:8001/.well-known/jwks.json
IDENTITY_INTROSPECT_URL=http://localhost:8001/v1/auth/introspect
SERVICE_AUTH_CLIENT_ID=healuxa-internal
SERVICE_AUTH_CLIENT_SECRET=dev-service-secret-change-me

NATS_URL=nats://localhost:4222
NATS_ENABLED=false
