# Healuxa Transformation Engine — Healuxa_TechSpec.md §25.1 / §25.2
# Copy to .env and adjust per environment: laptop | Docker infra | Dokploy production

# ── Shared (py-common ServiceSettings) ───────────────────────────────────────
APP_ENV=development
SERVICE_NAME=transformation-engine
LOG_LEVEL=INFO
INTERNAL_NETWORK=healuxa-net
TENANT_DEFAULT=healuxa-dubai

OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
JWT_PUBLIC_JWKS_URL=http://localhost:8001/.well-known/jwks.json

# ── PostgreSQL (transformation logical DB) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://healuxa:dev@localhost:5432/transformation
# Tests only:
# DATABASE_URL=postgresql+asyncpg://healuxa:dev@localhost:5432/transformation_test

# ── Identity introspection (dev Bearer fallback when Traefik headers absent) ─
IDENTITY_INTROSPECT_URL=http://localhost:8001/v1/auth/introspect
SERVICE_AUTH_CLIENT_ID=healuxa-internal
SERVICE_AUTH_CLIENT_SECRET=dev-service-secret-change-me

# ── NATS JetStream (optional in scaffold) ──────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_ENABLED=false

# ── TechSpec §25.2 placeholders (not used in scaffold) ─────────────────────────
MONGODB_URI=
AI_ORCHESTRATOR_URL=http://localhost:8017
ML_SERVICE_URL=http://localhost:8018
MATCHING_URL=http://localhost:8006
COMMERCIAL_URL=http://localhost:8020
KPI_OBJECTIVE=outcomes_retention_ltv
